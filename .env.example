# ---- Supabase / Postgres (pgvector) ----
# From Supabase dashboard → Project Settings → Database → Connection string (URI).
# Use the "Session" pooler URI for app usage; direct connection for migrations.
# If your password has special chars (@ : / $ * etc.), percent-encode them.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=

# ---- Embeddings (OpenAI) ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1024   # 3-small Matryoshka reduction → keeps vector(1024) schema

# ---- Generation LLM (provider-agnostic via LiteLLM) ----
# Set LLM_MODEL to any provider/model; fill in the matching key below.
LLM_MODEL=gpt-4o-mini
EVAL_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=

# ---- Observability (Langfuse) ----
# Langfuse Cloud has two regions with separate keys/projects — use the host
# that matches where you created your project (check your dashboard URL):
#   EU: https://cloud.langfuse.com
#   US: https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ---- Retrieval tuning ----
RETRIEVAL_TOP_K=20
TOP_N=6
# Min hybrid (RRF) score to keep a chunk; 0 = off (no reranker in this iteration).
RELEVANCE_FLOOR=0.0

# ---- Sparse retrieval (SPLADE) — optional overrides, sensible defaults in config ----
# SPLADE_MODEL=naver/splade-v3-distilbert
# SPLADE_TOP_K=256        # keep top-K terms per sparse vector
# SPLADE_BATCH_SIZE=8     # doc-encode batch size (memory bound)
